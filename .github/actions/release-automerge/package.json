{
  "name": "@code-assistants/release-automerge",
  "version": "0.2.3",
  "description": "Composite GitHub Action that merges an approved, all-green release PR.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "release": {
    "type": "github-action"
  },
  "agents": {
    "rules": "Bun",
    "language": "typescript"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "@code-assistants/actions-core": "workspace:*",
    "@octokit/rest": "22.0.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
