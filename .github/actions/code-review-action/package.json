{
  "name": "@code-assistants/code-review-action",
  "version": "1.4.0",
  "description": "Composite GitHub Action that runs AI code review on pull requests via Claude Code.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "release": {
    "type": "github-action"
  },
  "agents": {
    "rules": "Bun",
    "language": "typescript"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.126",
    "@code-assistants/actions-core": "workspace:*",
    "@octokit/rest": "22.0.1",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
