  });

  test("falls back to .release_bot/body inside the supplied cwd when no API key", () =>
    withTempDir(async (dir) => {
      delete process.env.ANTHROPIC_API_KEY;
      await Bun.write(join(dir, ".release_bot/body"), "## member changelog body");

