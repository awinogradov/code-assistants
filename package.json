{
  "name": "@code-assistants/monorepo",
  "version": "0.1.0",
  "description": "Autopilot: plan, implement, commit, PR, and monitor — skills and agents for AI-assisted development workflows",
  "private": true,
  "type": "module",
  "repository": "https://github.com/awinogradov/code-assistants",
  "author": "Tony Vi",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.9",
  "release": {
    "automerge": true
  },
  "agents": {
    "rules": "Bun",
    "language": "typescript"
  },
  "workspaces": [
    ".github/actions/files-sync",
    ".github/actions/agents-rules-sync",
    ".github/actions/release-action",
    ".github/actions/release-automerge",
    ".github/actions/code-review-action",
    ".github/actions/code-review-cost-monitor",
    ".github/actions/auto-label",
    ".github/actions/validate-actions",
    ".github/actions/perf-report-action",
    "claude-plugins/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"**/*.{md,json}\"",
    "format:check": "prettier --check \"**/*.{md,json}\"",
    "validate": "bun scripts/validate-plugins.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "bun run format:check && bun run validate && turbo run typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/types": "21.0.1",
    "@types/bun": "1.3.14",
    "gray-matter": "4.0.3",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "zod": "3.23.8"
  }
}
