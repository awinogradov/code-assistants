{
  "name": "autopilot",
  "version": "0.1.0",
  "description": "Autopilot: plan, implement, commit, PR, and monitor — skills and agents for AI-assisted development workflows",
  "private": true,
  "type": "module",
  "repository": "https://github.com/awinogradov/code-assistants",
  "author": "Tony Vi",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.9",
  "agents": {
    "rules": "Bun",
    "language": "typescript"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"**/*.{md,json}\"",
    "format:check": "prettier --check \"**/*.{md,json}\"",
    "validate": "bun scripts/validate-plugins.ts",
    "lint": "bun run format:check && bun run validate"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/types": "21.0.1",
    "@types/bun": "latest",
    "gray-matter": "4.0.3",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "zod": "3.23.8"
  }
}
